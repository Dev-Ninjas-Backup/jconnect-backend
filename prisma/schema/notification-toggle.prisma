model NotificationToggle {
  id                        String  @id @default(uuid())
  email                     Boolean @default(true)
  userUpdates               Boolean @default(true)
  serviceCreate             Boolean @default(true)
  review                    Boolean @default(true)
  post                      Boolean @default(true)
  message                   Boolean @default(true)
  Inquiry                   Boolean @default(true)
  userRegistration          Boolean @default(true)
  Service                   Boolean @default(true)
  follow                    Boolean @default(true)
  ORDER_UPDATE              Boolean @default(true)
  UploadProof               Boolean @default(true)
  PaymentReminder           Boolean @default(true)
  NEW_ORDER                 Boolean @default(true)
  UPLOAD_PROOF              Boolean @default(true)
  SERVICE_REQUEST_ACCEPTED  Boolean @default(true)
  SERVICE_REQUEST_REJECTED  Boolean @default(true)
  SERVICE_REQUEST_CANCELLED Boolean @default(true)
  PAYMENT_SUCCESSFUL        Boolean @default(true)
  PAYMENT_FAILED            Boolean @default(true)
  INQUIRY_RESPONSE          Boolean @default(true)
  REVIEW_RECEIVED           Boolean @default(true)
  POST_LIKED                Boolean @default(true)
  POST_COMMENTED            Boolean @default(true)
  POST_SHARED               Boolean @default(true)
  POST_REPLIED              Boolean @default(true)
  userId                    String
  user                      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification-toggle")
}
